#ifdef INCLUDE_EXAMPLES

#include <iostream>
#include <vector>

void example_basic_usage() {
    std::cout << "=== Basic Usage ===\n";
    std::cout << "Using: " << hnswlib::get_simd_type_string() << "\n\n";
    
    // Single vector normalization
    std::vector<float> vec = {1.0f, 2.0f, 3.0f, 4.0f};
    std::cout << "Before: [" << vec[0] << ", " << vec[1] << ", " 
              << vec[2] << ", " << vec[3] << "]\n";
    
    hnswlib::normalize_l2(vec.data(), vec.size());
    
    std::cout << "After:  [" << vec[0] << ", " << vec[1] << ", " 
              << vec[2] << ", " << vec[3] << "]\n";
    
    // Verify norm
    float norm = 0.0f;
    for (auto v : vec) norm += v * v;
    std::cout << "Norm:   " << std::sqrt(norm) << " (should be 1.0)\n\n";
}

void example_batch_normalization() {
    std::cout << "=== Batch Normalization ===\n";
    
    std::vector<std::vector<float>> embeddings = {
        {1.0f, 2.0f, 3.0f},
        {4.0f, 5.0f, 6.0f},
        {7.0f, 8.0f, 9.0f}
    };
    
    hnswlib::normalize_l2_batch(embeddings);
    
    for (size_t i = 0; i < embeddings.size(); i++) {
        std::cout << "Vector " << i << ": [";
        for (size_t j = 0; j < embeddings[i].size(); j++) {
            std::cout << embeddings[i][j];
            if (j < embeddings[i].size() - 1) std::cout << ", ";
        }
        std::cout << "]\n";
    }
    std::cout << "\n";
}

void example_with_bert() {
    std::cout << "=== BERT Embedding Example ===\n";
    
    const size_t dim = 768;
    std::vector<float> bert_embedding(dim);
    
    // Simulate BERT output (unnormalized)
    for (size_t i = 0; i < dim; i++) {
        bert_embedding[i] = (float)i / dim;
    }
    
    std::cout << "Before normalization:\n";
    std::cout << "  First values: [" << bert_embedding[0] << ", " 
              << bert_embedding[1] << ", " << bert_embedding[2] << "]\n";
    
    float norm_before = 0.0f;
    for (auto v : bert_embedding) norm_before += v * v;
    std::cout << "  L2 norm: " << std::sqrt(norm_before) << "\n\n";
    
    // Normalize using auto-selected SIMD
    hnswlib::normalize_l2(bert_embedding.data(), dim);
    
    std::cout << "After normalization:\n";
    std::cout << "  First values: [" << bert_embedding[0] << ", " 
              << bert_embedding[1] << ", " << bert_embedding[2] << "]\n";
    
    float norm_after = 0.0f;
    for (auto v : bert_embedding) norm_after += v * v;
    std::cout << "  L2 norm: " << std::sqrt(norm_after) << " (should be 1.0)\n";
}

void example_cached_function_pointer() {
    std::cout << "=== Cached Function Pointer ===\n";
    
    hnswlib::NormalizerCache normalizer;
    std::cout << "Using implementation: " << normalizer.get_implementation_name() << "\n";
    
    std::vector<float> vec = {3.0f, 4.0f};
    normalizer.normalize(vec.data(), vec.size());
    
    std::cout << "Normalized: [" << vec[0] << ", " << vec[1] << "]\n";
    std::cout << "Expected: [0.6, 0.8]\n";
}

