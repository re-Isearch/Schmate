#if defined(__AVX512F__)
#  include <immintrin.h>
#elif defined(__AVX2__)
#  include <immintrin.h>
#elif defined(__ARM_NEON) || defined(__ARM_NEON__)
#  include <arm_neon.h>
#endif

namespace hnswlib {

enum class QuantMode { BIN1=0, INT4=1, INT8=2 };
enum class BinMode  { STANDARD=0, BETTER=1 };

