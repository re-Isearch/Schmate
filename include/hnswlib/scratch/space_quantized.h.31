#pragma once
#include <vector>
#include <cmath>
#include <cstdint>
#include <cstring>
#include <algorithm>
#include <numeric>
#include <thread>
#include <atomic>
#include <cassert>
#include <iostream>
#include <fstream>
#include <mutex>

#include "hnswlib.h"
#include "pearson_corr.h"

#if defined(__AVX512F__)
  #include <immintrin.h>
  #define HNSW_SIMD_AVX512
#elif defined(__AVX2__)
  #include <immintrin.h>
  #define HNSW_SIMD_AVX2
#elif defined(__ARM_NEON) || defined(__ARM_NEON__)
  #include <arm_neon.h>
  #define HNSW_SIMD_NEON
#elif defined(__ARM_FEATURE_SVE)
  #include <arm_sve.h>
  #define HNSW_SIMD_SVE
#endif

namespace hnswlib {

enum class QuantMode { BIN1=0, INT158=1, INT4=2, INT8=3 };
enum class OptBinMode  { STANDARD=0, BETTER=1, CENTROID=2 };

// =============================================================================
template<typename T=float>
class SpaceQuantized : public SpaceInterface<float> {
public:
    using DISTFUNC_TYPE = DISTFUNC<float>;

    size_t dim;
    QuantMode qmode;
    OptBinMode bin_mode;
    size_t bytes_per_vector;

    std::vector<T> thresholds;
    std::vector<T> scale, minval, scale_sq;
    
    // Ternary quantization (INT158) state
    std::vector<T> ternary_threshold_low_;
    std::vector<T> ternary_threshold_high_;
    std::vector<T> ternary_scale_;
    
    // Centroid-based quantization state
    std::vector<T> centroid_;
    std::vector<T> sum_;
    size_t count_;
    std::vector<T> buffer_;
    size_t buffer_capacity_;
    size_t buffer_count_;
    mutable std::mutex centroid_mutex_;

    explicit SpaceQuantized(size_t dim_,
                            QuantMode qmode_,
                            OptBinMode bin_mode_ = OptBinMode::STANDARD,
                            const std::vector<std::vector<T>>* sample_embeddings = nullptr,
                            size_t buffer_capacity = 1000)
        : dim(dim_), qmode(qmode_), bin_mode(bin_mode_),
          count_(0), buffer_capacity_(buffer_capacity), buffer_count_(0) {
        assert(dim>0);
        
        // Initialize centroid structures if using CENTROID mode
        if (bin_mode == OptBinMode::CENTROID) {
            centroid_.assign(dim, T(0));
            sum_.assign(dim, T(0));
        }
        
        if (qmode==QuantMode::BIN1) {
            bytes_per_vector=(dim+7)/8;
            thresholds.assign(dim,T(0));
            
            if (bin_mode == OptBinMode::CENTROID) {
                if (sample_embeddings) {
                    train_centroid(*sample_embeddings);
                }
            } else {
                if (sample_embeddings) compute_thresholds(*sample_embeddings);
            }
        } else if (qmode==QuantMode::INT158) {
            // Ternary: 2 bits per value, stored as: 00=-1, 01=0, 10=+1, 11=unused
            bytes_per_vector = (dim * 2 + 7) / 8;
            ternary_threshold_low_.assign(dim, T(0));
            ternary_threshold_high_.assign(dim, T(0));
            ternary_scale_.assign(dim, T(1));
            
            if (sample_embeddings) {
                if (bin_mode == OptBinMode::CENTROID) {
                    train_centroid(*sample_embeddings);
                    compute_ternary_thresholds_from_centroid();
                } else {
                    compute_ternary_thresholds(*sample_embeddings);
                }
            }
        } else {
            // INT4 or INT8
            bytes_per_vector=(qmode==QuantMode::INT8)?dim:(dim+1)/2;
            scale.assign(dim,1); minval.assign(dim,0); scale_sq.assign(dim,1);
            
            if (sample_embeddings) {
                if (bin_mode == OptBinMode::CENTROID) {
                    train_centroid(*sample_embeddings);
                    compute_scale_min_from_centroid(*sample_embeddings, 
                                                   (qmode==QuantMode::INT8)?255.0:15.0);
                } else {
                    compute_scale_min(*sample_embeddings,
                                     (qmode==QuantMode::INT8)?255.0:15.0);
                }
            }
        }
    }

    // -- interface compliance --------------------------------------------------
    size_t get_data_size() override { return bytes_per_vector; }
    DISTFUNC_TYPE get_dist_func() override { return &SpaceQuantized::fstdist_; }
    void* get_dist_func_param() override { return this; }

    // -------------------------------------------------------------------------
    void quantize(const T* emb, uint8_t* out) const {
        switch(qmode){
            case QuantMode::BIN1: quantize_bin(emb,out); break;
            case QuantMode::INT158: quantize_ternary_simd(emb,out); break;
            case QuantMode::INT8: quantize_int8_simd(emb,out); break;
            case QuantMode::INT4: quantize_int4_simd(emb,out); break;
        }
    }
    
    // =================== CENTROID TRAINING ==================================
    void train_centroid(const std::vector<std::vector<T>>& samples) {
        std::lock_guard<std::mutex> lock(centroid_mutex_);
        
        const size_t n = samples.size();
        if (n == 0) return;
        
        std::fill(sum_.begin(), sum_.end(), T(0));
        count_ = 0;
        
        for (size_t i = 0; i < n; ++i) {
            for (size_t d = 0; d < dim; ++d) {
                sum_[d] += samples[i][d];
            }
        }
        
        count_ = n;
        update_centroid();
    }
    
    // Add vector for incremental training (call this in addPoint hook)
    void add_to_centroid(const T* emb) {
        if (bin_mode != OptBinMode::CENTROID) return;
        
        std::lock_guard<std::mutex> lock(centroid_mutex_);
        
        // Add to buffer
        for (size_t d = 0; d < dim; ++d) {
            buffer_.push_back(emb[d]);
        }
        buffer_count_++;
        
        // Initialize centroid with first vector if not trained
        if (count_ == 0 && buffer_count_ == 1) {
            for (size_t d = 0; d < dim; ++d) {
                sum_[d] = emb[d];
                centroid_[d] = emb[d];
            }
            count_ = 1;
        }
        
        // Retrain if buffer is full
        if (buffer_count_ >= buffer_capacity_) {
            // Keep buffer copy before merging
            std::vector<T> buffer_copy = buffer_;
            size_t buffer_count_copy = buffer_count_;
            
            // Merge buffer into running sum
            for (size_t i = 0; i < buffer_count_; ++i) {
                const T* vec = buffer_.data() + i * dim;
                for (size_t d = 0; d < dim; ++d) {
                    sum_[d] += vec[d];
                }
            }
            count_ += buffer_count_;
            update_centroid();
            
            // Update quantization params
            update_quantization_params(buffer_copy, buffer_count_copy);
            
            // Clear buffer
            buffer_.clear();
            buffer_count_ = 0;
        }
    }
    
    // Force retrain with current buffer
    void flush_centroid_buffer() {
        if (bin_mode != OptBinMode::CENTROID) return;
        
        std::lock_guard<std::mutex> lock(centroid_mutex_);
        if (buffer_count_ > 0) {
            // Keep buffer copy for update
            std::vector<T> buffer_copy = buffer_;
            size_t buffer_count_copy = buffer_count_;
            
            // Merge into centroid
            for (size_t i = 0; i < buffer_count_; ++i) {
                const T* vec = buffer_.data() + i * dim;
                for (size_t d = 0; d < dim; ++d) {
                    sum_[d] += vec[d];
                }
            }
            count_ += buffer_count_;
            update_centroid();
            
            // Update params
            update_quantization_params(buffer_copy, buffer_count_copy);
            
            // Clear buffer
            buffer_.clear();
            buffer_count_ = 0;
        }
    }
    
    // Save centroid state to disk
    bool save_centroid(const std::string& filepath) const {
        std::lock_guard<std::mutex> lock(centroid_mutex_);
        
        std::ofstream out(filepath, std::ios::binary);
        if (!out.is_open()) return false;
        
        // Write header
        out.write(reinterpret_cast<const char*>(&dim), sizeof(dim));
        out.write(reinterpret_cast<const char*>(&count_), sizeof(count_));
        out.write(reinterpret_cast<const char*>(&buffer_capacity_), sizeof(buffer_capacity_));
        
        // Write centroid
        out.write(reinterpret_cast<const char*>(centroid_.data()), 
                  dim * sizeof(T));
        
        // Write sum
        out.write(reinterpret_cast<const char*>(sum_.data()), 
                  dim * sizeof(T));
        
        // Write buffer
        out.write(reinterpret_cast<const char*>(&buffer_count_), sizeof(buffer_count_));
        if (buffer_count_ > 0) {
            out.write(reinterpret_cast<const char*>(buffer_.data()), 
                      buffer_count_ * dim * sizeof(T));
        }
        
        return out.good();
    }
    
    // Load centroid state from disk
    bool load_centroid(const std::string& filepath) {
        std::lock_guard<std::mutex> lock(centroid_mutex_);
        
        std::ifstream in(filepath, std::ios::binary);
        if (!in.is_open()) return false;
        
        // Read header
        size_t file_dim;
        in.read(reinterpret_cast<char*>(&file_dim), sizeof(file_dim));
        if (file_dim != dim) return false;
        
        in.read(reinterpret_cast<char*>(&count_), sizeof(count_));
        in.read(reinterpret_cast<char*>(&buffer_capacity_), sizeof(buffer_capacity_));
        
        // Read centroid
        centroid_.resize(dim);
        in.read(reinterpret_cast<char*>(centroid_.data()), dim * sizeof(T));
        
        // Read sum
        sum_.resize(dim);
        in.read(reinterpret_cast<char*>(sum_.data()), dim * sizeof(T));
        
        // Read buffer
        in.read(reinterpret_cast<char*>(&buffer_count_), sizeof(buffer_count_));
        if (buffer_count_ > 0) {
            buffer_.resize(buffer_count_ * dim);
            in.read(reinterpret_cast<char*>(buffer_.data()), 
                    buffer_count_ * dim * sizeof(T));
        }
        
        return in.good();
    }
    
    size_t get_centroid_count() const { return count_; }
    size_t get_buffer_count() const { return buffer_count_; }

private:
    // =================== DISTANCE ===========================================
    static float fstdist_(const void* p1, const void* p2, const void* param) {
        const auto* sp = reinterpret_cast<const SpaceQuantized*>(param);
        float dist = sp->compute_dist(reinterpret_cast<const uint8_t*>(p1),
                                       reinterpret_cast<const uint8_t*>(p2));
        // Safety check
        if (std::isnan(dist) || std::isinf(dist)) {
            std::cerr << "ERROR: Invalid distance computed: " << dist << std::endl;
            return 1e9;
        }
        return dist;
    }

    float compute_dist(const uint8_t* a, const uint8_t* b) const {
        if (qmode==QuantMode::BIN1) {
            // Hamming distance
            uint32_t acc=0;
            for(size_t i=0;i<bytes_per_vector;++i) acc+=__builtin_popcount(a[i]^b[i]);
            // For HNSW, smaller distance = more similar
            // Hamming distance already satisfies this (0 bits different = identical)
            // Normalize to [0,1] range for better numerical stability
            return float(acc) / float(dim);
        } else if (qmode==QuantMode::INT158) {
            // Ternary distance computation
            double acc = 0;
            size_t bit_idx = 0;
            for (size_t d = 0; d < dim; ++d) {
                // Extract 2 bits for each dimension
                size_t byte_idx = bit_idx / 8;
                size_t bit_off = bit_idx % 8;
                
                // Handle case where 2 bits span byte boundary
                uint8_t bits_a, bits_b;
                if (bit_off <= 6) {
                    // Both bits in same byte
                    bits_a = (a[byte_idx] >> bit_off) & 0x03;
                    bits_b = (b[byte_idx] >> bit_off) & 0x03;
                } else {
                    // Bits span two bytes (bit_off == 7)
                    bits_a = ((a[byte_idx] >> 7) & 0x01) | 
                            ((a[byte_idx + 1] & 0x01) << 1);
                    bits_b = ((b[byte_idx] >> 7) & 0x01) | 
                            ((b[byte_idx + 1] & 0x01) << 1);
                }
                
                // Decode: 00=-1, 01=0, 10=+1
                int val_a = (bits_a == 0) ? -1 : ((bits_a == 1) ? 0 : 1);
                int val_b = (bits_b == 0) ? -1 : ((bits_b == 1) ? 0 : 1);
                
                int diff = val_a - val_b;
                acc += diff * diff * double(ternary_scale_[d]);
                
                bit_idx += 2;
            }
            return float(acc);
        } else if (qmode==QuantMode::INT8) {
            // INT8 distance with proper per-dimension scaling
            // CRITICAL: Must handle signed differences correctly
            double acc = 0;
            for(size_t i = 0; i < dim; ++i) {
                // Cast to signed int to handle negative differences
                int diff = (int)a[i] - (int)b[i];
                acc += diff * diff * double(scale_sq[i]);
            }
            return float(acc);
        } else { // INT4
            double acc=0;
            for(size_t d=0;d<dim;d+=2){
                uint8_t ba=a[d>>1], bb=b[d>>1];
                uint8_t a0=ba&0x0F,a1=ba>>4,b0=bb&0x0F,b1=bb>>4;
                int diff0=int(a0)-int(b0);
                acc+=diff0*diff0*double(scale_sq[d]);
                if(d+1<dim){int diff1=int(a1)-int(b1); acc+=diff1*diff1*double(scale_sq[d+1]);}
            }
            return float(acc);
        }
    }

    // =================== SCALING / THRESHOLDS ===============================
    void compute_ternary_thresholds(const std::vector<std::vector<T>>& samples) {
        const size_t n = samples.size();
        std::vector<T> col(n);
        
        for (size_t d = 0; d < dim; ++d) {
            for (size_t i = 0; i < n; ++i) col[i] = samples[i][d];
            std::sort(col.begin(), col.end());
            
            // Use 33rd and 67th percentiles as thresholds
            size_t idx_low = n / 3;
            size_t idx_high = (2 * n) / 3;
            
            ternary_threshold_low_[d] = col[idx_low];
            ternary_threshold_high_[d] = col[idx_high];
            
            // Compute scale for distance calculation
            T range = col[n-1] - col[0];
            ternary_scale_[d] = (range > 0) ? (range * range) : T(1);
        }
    }
    
    void compute_ternary_thresholds_from_centroid() {
        // Use centroid-based approach for ternary thresholds
        // Set thresholds at +/- one standard deviation from centroid
        // This is a simple heuristic; could be improved with actual std dev calculation
        for (size_t d = 0; d < dim; ++d) {
            T c = centroid_[d];
            // Simple heuristic: use +/- 0.5 * centroid value as thresholds
            T offset = std::abs(c) * T(0.5);
            if (offset == 0) offset = T(0.1); // Avoid zero offset
            
            ternary_threshold_low_[d] = c - offset;
            ternary_threshold_high_[d] = c + offset;
            ternary_scale_[d] = offset * offset;
        }
    }
    
    void compute_scale_min_from_centroid(const std::vector<std::vector<T>>& samples, double levels) {
        // Compute min/max but center the quantization around the centroid
        const size_t n = samples.size();
        for (size_t d = 0; d < dim; ++d) {
            T lo = samples[0][d], hi = lo;
            for (size_t i = 1; i < n; ++i) {
                T v = samples[i][d];
                if (v < lo) lo = v;
                if (v > hi) hi = v;
            }
            
            // Center around centroid
            T c = centroid_[d];
            T range = std::max(std::abs(hi - c), std::abs(lo - c)) * T(2);
            
            minval[d] = c - range / T(2);
            scale[d] = range / levels;
            if (scale[d] == 0) scale[d] = 1;
            scale_sq[d] = scale[d] * scale[d];
        }
    }
    
    void compute_thresholds(const std::vector<std::vector<T>>& samples){
        const size_t n=samples.size();
        std::vector<T> col(n);
        for(size_t d=0;d<dim;++d){
            for(size_t i=0;i<n;++i) col[i]=samples[i][d];
            if(bin_mode==OptBinMode::STANDARD){
                std::nth_element(col.begin(),col.begin()+n/2,col.end());
                thresholds[d]=col[n/2];
            }else{
                std::sort(col.begin(),col.end());
                T best_thr=col[n/2]; float best_corr=-1;
                for(int k=1;k<99;++k){
                    size_t id=k*n/100; T thr=col[id];
                    std::vector<float> bits(n);
                    for(size_t i=0;i<n;++i) bits[i]=(col[i]>thr)?1.f:0.f;
                    float corr=std::fabs(pearson_corr(bits,col));
                    if(corr>best_corr){best_corr=corr;best_thr=thr;}
                }
                thresholds[d]=best_thr;
            }
        }
    }

    void compute_scale_min(const std::vector<std::vector<T>>& samples,double levels){
        const size_t n=samples.size();
        for(size_t d=0;d<dim;++d){
            T lo=samples[0][d],hi=lo;
            for(size_t i=1;i<n;++i){T v=samples[i][d]; if(v<lo)lo=v; if(v>hi)hi=v;}
            minval[d]=lo; 
            scale[d]=(hi-lo)/levels; 
            if(scale[d]==0)scale[d]=1; 
            scale_sq[d]=scale[d]*scale[d];
        }
        
        // Debug: Print scale info for first dimension
        if (dim > 0) {
            std::cout << "  [Scale debug: dim0 range=[" << minval[0] << "," << (minval[0] + scale[0]*levels) 
                      << "], scale=" << scale[0] << "]" << std::flush;
        }
    }

    // =================== QUANTIZATION ======================================
    void quantize_ternary_simd(const T* emb, uint8_t* out) const {
        std::memset(out, 0, bytes_per_vector);
        
        size_t bit_idx = 0;
        for (size_t d = 0; d < dim; ++d) {
            // Ternary quantization: -1, 0, +1
            uint8_t code;
            if (emb[d] < ternary_threshold_low_[d]) {
                code = 0b00; // -1
            } else if (emb[d] > ternary_threshold_high_[d]) {
                code = 0b10; // +1
            } else {
                code = 0b01; // 0
            }
            
            // Pack 2 bits into output
            size_t byte_idx = bit_idx / 8;
            size_t bit_off = bit_idx % 8;
            out[byte_idx] |= (code << bit_off);
            
            bit_idx += 2;
        }
    }
    
    void quantize_bin(const T* emb,uint8_t* out) const {
        std::memset(out,0,bytes_per_vector);
        
        const T* thr = (bin_mode == OptBinMode::CENTROID) ? centroid_.data() : thresholds.data();
        const bool use_gte = (bin_mode == OptBinMode::CENTROID);
        
#if defined(HNSW_SIMD_AVX512)
        size_t i = 0;
        for (; i + 15 < dim; i += 16) {
            __m512 v = _mm512_loadu_ps(emb + i);
            __m512 t = _mm512_loadu_ps(thr + i);
            __mmask16 cmp = use_gte ? _mm512_cmp_ps_mask(v, t, _CMP_GE_OQ) 
                                    : _mm512_cmp_ps_mask(v, t, _CMP_GT_OQ);
            uint16_t mask = cmp;
            for (int b = 0; b < 16; ++b) {
                if (mask & (1 << b)) {
                    size_t idx = i + b;
                    out[idx >> 3] |= uint8_t(1u << (idx & 7));
                }
            }
        }
        for (; i < dim; ++i) {
            if ((use_gte && emb[i] >= thr[i]) || (!use_gte && emb[i] > thr[i])) {
                out[i >> 3] |= uint8_t(1u << (i & 7));
            }
        }
#elif defined(HNSW_SIMD_AVX2)
        size_t i = 0;
        for (; i + 7 < dim; i += 8) {
            __m256 v = _mm256_loadu_ps(emb + i);
            __m256 t = _mm256_loadu_ps(thr + i);
            __m256 cmp = use_gte ? _mm256_cmp_ps(v, t, _CMP_GE_OQ) 
                                 : _mm256_cmp_ps(v, t, _CMP_GT_OQ);
            int mask = _mm256_movemask_ps(cmp);
            for (int b = 0; b < 8; ++b) {
                if (mask & (1 << b)) {
                    size_t idx = i + b;
                    out[idx >> 3] |= uint8_t(1u << (idx & 7));
                }
            }
        }
        for (; i < dim; ++i) {
            if ((use_gte && emb[i] >= thr[i]) || (!use_gte && emb[i] > thr[i])) {
                out[i >> 3] |= uint8_t(1u << (i & 7));
            }
        }
#elif defined(HNSW_SIMD_NEON)
        size_t i = 0;
        for (; i + 3 < dim; i += 4) {
            float32x4_t v = vld1q_f32(emb + i);
            float32x4_t t = vld1q_f32(thr + i);
            uint32x4_t cmp = use_gte ? vcgeq_f32(v, t) : vcgtq_f32(v, t);
            uint32_t mask[4];
            vst1q_u32(mask, cmp);
            for (int b = 0; b < 4; ++b) {
                if (mask[b]) {
                    size_t idx = i + b;
                    out[idx >> 3] |= uint8_t(1u << (idx & 7));
                }
            }
        }
        for (; i < dim; ++i) {
            if ((use_gte && emb[i] >= thr[i]) || (!use_gte && emb[i] > thr[i])) {
                out[i >> 3] |= uint8_t(1u << (i & 7));
            }
        }
#elif defined(HNSW_SIMD_SVE)
        size_t i = 0;
        svbool_t pg = svptrue_b32();
        size_t vl = svcntw();
        for (; i + vl <= dim; i += vl) {
            svfloat32_t v = svld1_f32(pg, emb + i);
            svfloat32_t t = svld1_f32(pg, thr + i);
            svbool_t cmp = use_gte ? svcmpge_f32(pg, v, t) : svcmpgt_f32(pg, v, t);
            uint32_t mask[svcntw()];
            svst1_u32(svptrue_b32(), mask, svdup_n_u32_z(cmp, 1));
            for (size_t b = 0; b < vl && (i + b) < dim; ++b) {
                if (mask[b]) {
                    size_t idx = i + b;
                    out[idx >> 3] |= uint8_t(1u << (idx & 7));
                }
            }
        }
        for (; i < dim; ++i) {
            if ((use_gte && emb[i] >= thr[i]) || (!use_gte && emb[i] > thr[i])) {
                out[i >> 3] |= uint8_t(1u << (i & 7));
            }
        }
#else
        // Scalar fallback
        for (size_t i = 0; i < dim; ++i) {
            if ((use_gte && emb[i] >= thr[i]) || (!use_gte && emb[i] > thr[i])) {
                out[i >> 3] |= uint8_t(1u << (i & 7));
            }
        }
#endif
    }

    void quantize_int8_simd(const T* emb,uint8_t* out) const {
#if defined(HNSW_SIMD_AVX2)
        size_t i = 0;
        __m256 vzero = _mm256_setzero_ps();
        __m256 v255 = _mm256_set1_ps(255.0f);
        for (; i + 7 < dim; i += 8) {
            __m256 v = _mm256_loadu_ps(emb + i);
            __m256 vmin = _mm256_loadu_ps(minval.data() + i);
            __m256 vscale = _mm256_loadu_ps(scale.data() + i);
            __m256 scaled = _mm256_div_ps(_mm256_sub_ps(v, vmin), vscale);
            scaled = _mm256_round_ps(scaled, _MM_FROUND_TO_NEAREST_INT | _MM_FROUND_NO_EXC);
            scaled = _mm256_max_ps(vzero, _mm256_min_ps(v255, scaled));
            alignas(32) float tmp[8];
            _mm256_store_ps(tmp, scaled);
            for (int j = 0; j < 8; ++j) {
                out[i + j] = uint8_t(tmp[j]);
            }
        }
        for (; i < dim; ++i) {
            float v = (emb[i] - minval[i]) / scale[i];
            int qi = std::clamp(int(std::nearbyint(v)), 0, 255);
            out[i] = uint8_t(qi);
        }
#elif defined(HNSW_SIMD_NEON)
        size_t i = 0;
        float32x4_t vzero = vdupq_n_f32(0.0f);
        float32x4_t v255 = vdupq_n_f32(255.0f);
        for (; i + 3 < dim; i += 4) {
            float32x4_t v = vld1q_f32(emb + i);
            float32x4_t vmin = vld1q_f32(minval.data() + i);
            float32x4_t vscale = vld1q_f32(scale.data() + i);
            float32x4_t scaled = vdivq_f32(vsubq_f32(v, vmin), vscale);
            int32x4_t rounded = vcvtnq_s32_f32(scaled);
            scaled = vcvtq_f32_s32(rounded);
            scaled = vmaxq_f32(vzero, vminq_f32(v255, scaled));
            float tmp[4];
            vst1q_f32(tmp, scaled);
            for (int j = 0; j < 4; ++j) {
                out[i + j] = uint8_t(tmp[j]);
            }
        }
        for (; i < dim; ++i) {
            float v = (emb[i] - minval[i]) / scale[i];
            int qi = std::clamp(int(std::nearbyint(v)), 0, 255);
            out[i] = uint8_t(qi);
        }
#else
        for (size_t i = 0; i < dim; ++i) {
            float v = (emb[i] - minval[i]) / scale[i];
            int qi = std::clamp(int(std::nearbyint(v)), 0, 255);
            out[i] = uint8_t(qi);
        }
#endif
    }

    void quantize_int4_simd(const T* emb,uint8_t* out) const {
#if defined(HNSW_SIMD_AVX2)
        size_t idx = 0;
        size_t d = 0;
        __m256 vzero = _mm256_setzero_ps();
        __m256 v15 = _mm256_set1_ps(15.0f);
        
        for (; d + 15 < dim; d += 16) {
            // Load 16 values
            __m256 v0 = _mm256_loadu_ps(emb + d);
            __m256 v1 = _mm256_loadu_ps(emb + d + 8);
            __m256 vmin0 = _mm256_loadu_ps(minval.data() + d);
            __m256 vmin1 = _mm256_loadu_ps(minval.data() + d + 8);
            __m256 vscale0 = _mm256_loadu_ps(scale.data() + d);
            __m256 vscale1 = _mm256_loadu_ps(scale.data() + d + 8);
            
            // Scale and quantize
            __m256 scaled0 = _mm256_div_ps(_mm256_sub_ps(v0, vmin0), vscale0);
            __m256 scaled1 = _mm256_div_ps(_mm256_sub_ps(v1, vmin1), vscale1);
            scaled0 = _mm256_round_ps(scaled0, _MM_FROUND_TO_NEAREST_INT | _MM_FROUND_NO_EXC);
            scaled1 = _mm256_round_ps(scaled1, _MM_FROUND_TO_NEAREST_INT | _MM_FROUND_NO_EXC);
            scaled0 = _mm256_max_ps(vzero, _mm256_min_ps(v15, scaled0));
            scaled1 = _mm256_max_ps(vzero, _mm256_min_ps(v15, scaled1));
            
            alignas(32) float tmp0[8], tmp1[8];
            _mm256_store_ps(tmp0, scaled0);
            _mm256_store_ps(tmp1, scaled1);
            
            // Pack pairs
            for (int j = 0; j < 8; ++j) {
                uint8_t q0 = uint8_t(tmp0[j]);
                uint8_t q1 = uint8_t(tmp1[j]);
                out[idx++] = uint8_t((q1 << 4) | (q0 & 0x0F));
            }
        }
        
        // Handle remaining elements
        for (; d < dim; d += 2) {
            float v0 = (emb[d] - minval[d]) / scale[d];
            int q0 = std::clamp(int(std::nearbyint(v0)), 0, 15);
            int q1 = 0;
            if (d + 1 < dim) {
                float v1 = (emb[d + 1] - minval[d + 1]) / scale[d + 1];
                q1 = std::clamp(int(std::nearbyint(v1)), 0, 15);
            }
            out[idx++] = uint8_t((q1 << 4) | (q0 & 0x0F));
        }
#elif defined(HNSW_SIMD_NEON)
        size_t idx = 0;
        size_t d = 0;
        float32x4_t vzero = vdupq_n_f32(0.0f);
        float32x4_t v15 = vdupq_n_f32(15.0f);
        
        for (; d + 7 < dim; d += 8) {
            // Load 8 values
            float32x4_t v0 = vld1q_f32(emb + d);
            float32x4_t v1 = vld1q_f32(emb + d + 4);
            float32x4_t vmin0 = vld1q_f32(minval.data() + d);
            float32x4_t vmin1 = vld1q_f32(minval.data() + d + 4);
            float32x4_t vscale0 = vld1q_f32(scale.data() + d);
            float32x4_t vscale1 = vld1q_f32(scale.data() + d + 4);
            
            // Scale and quantize
            float32x4_t scaled0 = vdivq_f32(vsubq_f32(v0, vmin0), vscale0);
            float32x4_t scaled1 = vdivq_f32(vsubq_f32(v1, vmin1), vscale1);
            int32x4_t rounded0 = vcvtnq_s32_f32(scaled0);
            int32x4_t rounded1 = vcvtnq_s32_f32(scaled1);
            scaled0 = vcvtq_f32_s32(rounded0);
            scaled1 = vcvtq_f32_s32(rounded1);
            scaled0 = vmaxq_f32(vzero, vminq_f32(v15, scaled0));
            scaled1 = vmaxq_f32(vzero, vminq_f32(v15, scaled1));
            
            float tmp0[4], tmp1[4];
            vst1q_f32(tmp0, scaled0);
            vst1q_f32(tmp1, scaled1);
            
            // Pack pairs
            for (int j = 0; j < 4; ++j) {
                uint8_t q0 = uint8_t(tmp0[j]);
                uint8_t q1 = uint8_t(tmp1[j]);
                out[idx++] = uint8_t((q1 << 4) | (q0 & 0x0F));
            }
        }
        
        // Handle remaining elements
        for (; d < dim; d += 2) {
            float v0 = (emb[d] - minval[d]) / scale[d];
            int q0 = std::clamp(int(std::nearbyint(v0)), 0, 15);
            int q1 = 0;
            if (d + 1 < dim) {
                float v1 = (emb[d + 1] - minval[d + 1]) / scale[d + 1];
                q1 = std::clamp(int(std::nearbyint(v1)), 0, 15);
            }
            out[idx++] = uint8_t((q1 << 4) | (q0 & 0x0F));
        }
#else
        size_t idx = 0;
        for (size_t d = 0; d < dim; d += 2) {
            float v0 = (emb[d] - minval[d]) / scale[d];
            int q0 = std::clamp(int(std::nearbyint(v0)), 0, 15);
            int q1 = 0;
            if (d + 1 < dim) {
                float v1 = (emb[d + 1] - minval[d + 1]) / scale[d + 1];
                q1 = std::clamp(int(std::nearbyint(v1)), 0, 15);
            }
            out[idx++] = uint8_t((q1 << 4) | (q0 & 0x0F));
        }
#endif
    }
    
    // =================== CENTROID HELPERS ==================================
    void update_centroid() {
        if (count_ == 0) return;
        for (size_t d = 0; d < dim; ++d) {
            centroid_[d] = sum_[d] / T(count_);
        }
    }
    
    void retrain_from_buffer() {
        if (buffer_count_ == 0) return;
        
        // Keep a copy of buffer before clearing for scale updates
        std::vector<T> buffer_copy = buffer_;
        size_t buffer_count_copy = buffer_count_;
        
        // Merge buffer into running sum
        for (size_t i = 0; i < buffer_count_; ++i) {
            const T* vec = buffer_.data() + i * dim;
            for (size_t d = 0; d < dim; ++d) {
                sum_[d] += vec[d];
            }
        }
        
        count_ += buffer_count_;
        update_centroid();
        
        // Update quantization parameters using buffered samples
        update_quantization_params(buffer_copy, buffer_count_copy);
        
        // Clear buffer
        buffer_.clear();
        buffer_count_ = 0;
    }
    
    void update_quantization_params(const std::vector<T>& buffer_samples, size_t n_samples) {
        // Update quantization parameters based on new centroid
        if (qmode == QuantMode::BIN1) {
            // For binary quantization with centroid, the centroid itself is the threshold
            // Already updated in update_centroid(), nothing extra needed
            // The quantize_bin() function uses centroid_[d] directly
        } else if (qmode == QuantMode::INT158) {
            compute_ternary_thresholds_from_centroid();
        } else if (qmode == QuantMode::INT4 || qmode == QuantMode::INT8) {
            // Recompute scale/min using buffer samples and new centroid
            double levels = (qmode == QuantMode::INT8) ? 255.0 : 15.0;
            
            for (size_t d = 0; d < dim; ++d) {
                T lo = buffer_samples[d], hi = lo;
                
                // Find min/max in buffer for this dimension
                for (size_t i = 1; i < n_samples; ++i) {
                    T v = buffer_samples[i * dim + d];
                    if (v < lo) lo = v;
                    if (v > hi) hi = v;
                }
                
                // Center around centroid
                T c = centroid_[d];
                T range = std::max(std::abs(hi - c), std::abs(lo - c)) * T(2);
                
                // Use exponential moving average to smooth updates
                T alpha = T(0.3); // Smoothing factor
                T new_minval = c - range / T(2);
                T new_scale = range / levels;
                if (new_scale == 0) new_scale = 1;
                
                minval[d] = alpha * new_minval + (T(1) - alpha) * minval[d];
                scale[d] = alpha * new_scale + (T(1) - alpha) * scale[d];
                scale_sq[d] = scale[d] * scale[d];
            }
        }
    }
};

} // namespace hnswlib

