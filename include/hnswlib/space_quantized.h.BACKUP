    dim, 
    hnswlib::QuantMode::BIN1, 
    hnswlib::OptBinMode::CENTROID,
    &initial_samples,  // optional initial training
    1000  // buffer capacity for incremental training
);

// Create HNSW index
auto index = new hnswlib::HierarchicalNSW<float>(space, max_elements);

// Add points with incremental training
for (size_t i = 0; i < num_vectors; ++i) {
    // Feed vector to centroid for incremental learning
    space->add_to_centroid(vectors[i].data());
    
    // Quantize and add to index
    std::vector<uint8_t> code(space->get_data_size());
    space->quantize(vectors[i].data(), code.data());
    index->addPoint(code.data(), i);
    
    // Periodically save
    if (i % 10000 == 0) {
        index->saveIndex("index.bin");
        space->save_centroid("centroid.bin");
    }
}

// Force final retrain
space->flush_centroid_buffer();
space->save_centroid("centroid.bin");

// Load later
space->load_centroid("centroid.bin");
*/
