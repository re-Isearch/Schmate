\subsection{Classes and APIs}\label{classes-and-apis}

\subsubsection{\texorpdfstring{\texttt{SBertGGML}}{SBertGGML}}\label{sbertggml}

\textbf{Purpose:} Wraps the GGML-based SBERT model: tokenization,
evaluation, and optional normalization for cosine search.

\textbf{Key members (example):}

\begin{Shaded}
\begin{Highlighting}[]
\KeywordTok{struct}\NormalTok{ SBertGGML }\OperatorTok{\{}
\NormalTok{    bert\_ctx }\OperatorTok{*}\NormalTok{ctx }\OperatorTok{=} \KeywordTok{nullptr}\OperatorTok{;}       \CommentTok{// internal ggml model context}
    \DataTypeTok{size\_t}\NormalTok{ n\_embd }\OperatorTok{=} \DecValTok{0}\OperatorTok{;}             \CommentTok{// embedding dimension}
    \DataTypeTok{bool}\NormalTok{ normalize\_for\_cosine }\OperatorTok{=} \KeywordTok{true}\OperatorTok{;}

    \KeywordTok{explicit}\NormalTok{ SBertGGML}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{model\_path}\OperatorTok{);}
    \OperatorTok{\textasciitilde{}}\NormalTok{SBertGGML}\OperatorTok{();}

    \BuiltInTok{std::}\NormalTok{vector}\OperatorTok{\textless{}}\DataTypeTok{float}\OperatorTok{\textgreater{}}\NormalTok{ encode\_text}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{text}\OperatorTok{,} \DataTypeTok{bool}\NormalTok{ debug}\OperatorTok{=}\KeywordTok{false}\OperatorTok{);}
\OperatorTok{\};}
\end{Highlighting}
\end{Shaded}

\textbf{Usage notes:} - Initialize once per thread or keep a shared
instance with thread-safe encoder usage (or guard concurrency). - When
\texttt{cfg.metric\ ==\ "cosine"}, \texttt{encode\_text()} should
normalize embeddings (L2 norm = 1) before returning them. Do
\textbf{not} normalize if the runtime metric is L2. - Provide a small
debug mode that prints token counts, first N embedding components, and
norm.

\textbf{Example:}

\begin{Shaded}
\begin{Highlighting}[]
\NormalTok{SBertGGML encoder}\OperatorTok{(}\StringTok{"/path/to/sbert.ggml"}\OperatorTok{);}
\KeywordTok{auto}\NormalTok{ emb }\OperatorTok{=}\NormalTok{ encoder}\OperatorTok{.}\NormalTok{encode\_text}\OperatorTok{(}\StringTok{"He develops in C++"}\OperatorTok{,} \KeywordTok{true}\OperatorTok{);}
\end{Highlighting}
\end{Shaded}

\begin{center}\rule{0.5\linewidth}{0.5pt}\end{center}

\subsubsection{\texorpdfstring{\texttt{OffsetFile}}{OffsetFile}}\label{offsetfile}

\textbf{Purpose:} Persistent, memory-mapped table of
\texttt{OffsetEntry} structures that map HNSW labels to sentence
metadata (SID, token spans, file byte offsets).

\textbf{Data layout}

\begin{Shaded}
\begin{Highlighting}[]
\KeywordTok{struct}\NormalTok{ OffsetEntry }\OperatorTok{\{}
    \DataTypeTok{int64\_t}\NormalTok{ sentence\_id}\OperatorTok{;}       \CommentTok{// externally provided persistent ID}
    \DataTypeTok{int32\_t}\NormalTok{ token\_start}\OperatorTok{;}
    \DataTypeTok{int32\_t}\NormalTok{ token\_end}\OperatorTok{;}
    \DataTypeTok{int64\_t}\NormalTok{ file\_start}\OperatorTok{;}        \CommentTok{// byte offset in sentences file (inclusive)}
    \DataTypeTok{int64\_t}\NormalTok{ file\_end}\OperatorTok{;}          \CommentTok{// byte offset in sentences file (exclusive)}
\OperatorTok{\};}
\end{Highlighting}
\end{Shaded}

\textbf{Key methods (example):}

\begin{Shaded}
\begin{Highlighting}[]
\KeywordTok{class}\NormalTok{ OffsetFile }\OperatorTok{\{}
\KeywordTok{public}\OperatorTok{:}
\NormalTok{    OffsetFile}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{path}\OperatorTok{,} \DataTypeTok{size\_t}\NormalTok{ max\_entries}\OperatorTok{,} \DataTypeTok{size\_t}\NormalTok{ header\_size }\OperatorTok{=} \DecValTok{0}\OperatorTok{);}
    \OperatorTok{\textasciitilde{}}\NormalTok{OffsetFile}\OperatorTok{();}

\NormalTok{    OffsetEntry get}\OperatorTok{(}\DataTypeTok{size\_t}\NormalTok{ label}\OperatorTok{)} \AttributeTok{const}\OperatorTok{;}
\NormalTok{    OffsetEntry }\OperatorTok{*}\NormalTok{get\_mut}\OperatorTok{(}\DataTypeTok{size\_t}\NormalTok{ label}\OperatorTok{);}
    \DataTypeTok{void}\NormalTok{ set}\OperatorTok{(}\DataTypeTok{size\_t}\NormalTok{ label}\OperatorTok{,} \AttributeTok{const}\NormalTok{ OffsetEntry }\OperatorTok{\&}\NormalTok{entry}\OperatorTok{);}
    \DataTypeTok{void}\NormalTok{ for\_each}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{function}\OperatorTok{\textless{}}\DataTypeTok{void}\OperatorTok{(}\DataTypeTok{size\_t}\OperatorTok{,}\AttributeTok{const}\NormalTok{ OffsetEntry}\OperatorTok{\&)\textgreater{}} \OperatorTok{\&}\NormalTok{fn}\OperatorTok{)} \AttributeTok{const}\OperatorTok{;}

    \CommentTok{// flush single entry or whole file}
    \DataTypeTok{void}\NormalTok{ flush}\OperatorTok{(}\DataTypeTok{size\_t}\NormalTok{ label }\OperatorTok{=}\NormalTok{ SIZE\_MAX}\OperatorTok{);}
    \DataTypeTok{size\_t}\NormalTok{ entry\_address}\OperatorTok{(}\DataTypeTok{size\_t}\NormalTok{ label}\OperatorTok{)} \AttributeTok{const}\OperatorTok{;}
    \DataTypeTok{size\_t}\NormalTok{ count}\OperatorTok{()} \AttributeTok{const}\OperatorTok{;}
\OperatorTok{\};}
\end{Highlighting}
\end{Shaded}

\textbf{Behavior \& notes:} - The file is usually created with a small
header area (for manifest/meta) followed by an array of
\texttt{OffsetEntry} entries. - \texttt{get\_mut()} returns a pointer
directly into the mmap region for in-place updates; remember to
\texttt{flush(label)} after modifying. - The API provides a small
\texttt{for\_each()} helper for scanning all entries efficiently without
materializing the whole table in memory.

\begin{center}\rule{0.5\linewidth}{0.5pt}\end{center}

\subsubsection{\texorpdfstring{\texttt{BertIndex}}{BertIndex}}\label{bertindex}

\textbf{Purpose:} Single-shard index object combining SBERT encoder,
HNSW graph, the \texttt{OffsetFile}, and the \texttt{sentences} text
file. Responsible for adding entries, searching, removing, undeleting,
flushing and saving to disk.

\textbf{Key members (example):}

\begin{Shaded}
\begin{Highlighting}[]
\KeywordTok{class}\NormalTok{ BertIndex }\OperatorTok{\{}
\KeywordTok{public}\OperatorTok{:}
\NormalTok{    BertIndex}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{base\_name}\OperatorTok{,} \AttributeTok{const}\NormalTok{ HnswConfig }\OperatorTok{\&}\NormalTok{cfg}\OperatorTok{);}
    \OperatorTok{\textasciitilde{}}\NormalTok{BertIndex}\OperatorTok{();}

    \DataTypeTok{size\_t}\NormalTok{ append}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{sentence}\OperatorTok{,} \DataTypeTok{int64\_t}\NormalTok{ sentence\_id}\OperatorTok{);}
    \DataTypeTok{void}\NormalTok{ appendid}\OperatorTok{(}\DataTypeTok{int64\_t}\NormalTok{ sentence\_id}\OperatorTok{,} \AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{sentence}\OperatorTok{);}
    \DataTypeTok{void}\NormalTok{ remove}\OperatorTok{(}\DataTypeTok{size\_t}\NormalTok{ label}\OperatorTok{);}
    \DataTypeTok{void}\NormalTok{ undelete}\OperatorTok{(}\DataTypeTok{size\_t}\NormalTok{ label}\OperatorTok{);}

    \BuiltInTok{std::}\NormalTok{vector}\OperatorTok{\textless{}}\NormalTok{SearchResult}\OperatorTok{\textgreater{}}\NormalTok{ knn}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{query}\OperatorTok{,} \DataTypeTok{size\_t}\NormalTok{ k}\OperatorTok{);}
    \BuiltInTok{std::}\NormalTok{vector}\OperatorTok{\textless{}}\NormalTok{SearchResult}\OperatorTok{\textgreater{}}\NormalTok{ radius}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{query}\OperatorTok{,} \DataTypeTok{float}\NormalTok{ radius}\OperatorTok{);}
    \BuiltInTok{std::}\NormalTok{vector}\OperatorTok{\textless{}}\NormalTok{SearchResult}\OperatorTok{\textgreater{}}\NormalTok{ relative}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{query}\OperatorTok{,} \DataTypeTok{float}\NormalTok{ alpha}\OperatorTok{);}
    \BuiltInTok{std::}\NormalTok{vector}\OperatorTok{\textless{}}\NormalTok{SearchResult}\OperatorTok{\textgreater{}}\NormalTok{ adaptive}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{query}\OperatorTok{,} \DataTypeTok{float}\NormalTok{ alpha}\OperatorTok{,} \DataTypeTok{size\_t}\NormalTok{ minN}\OperatorTok{,} \DataTypeTok{size\_t}\NormalTok{ lookahead}\OperatorTok{,} \DataTypeTok{float}\NormalTok{ gapDelta}\OperatorTok{);}

    \DataTypeTok{void}\NormalTok{ flush}\OperatorTok{();}      \CommentTok{// flush offsets and optionally save HNSW}
    \DataTypeTok{void}\NormalTok{ save}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{path}\OperatorTok{);} \CommentTok{// persist HNSW + optional metadata}
    \DataTypeTok{void}\NormalTok{ load}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{path}\OperatorTok{);} \CommentTok{// load HNSW + metadata}
    \DataTypeTok{size\_t}\NormalTok{ size}\OperatorTok{()} \AttributeTok{const}\OperatorTok{;}
\OperatorTok{\};}
\end{Highlighting}
\end{Shaded}

\textbf{SearchResult struct:}

\begin{Shaded}
\begin{Highlighting}[]
\KeywordTok{struct}\NormalTok{ SearchResult }\OperatorTok{\{}
    \DataTypeTok{float}\NormalTok{ score}\OperatorTok{;}
    \DataTypeTok{size\_t}\NormalTok{ label}\OperatorTok{;}
    \DataTypeTok{int64\_t}\NormalTok{ sentence\_id}\OperatorTok{;}
    \DataTypeTok{size\_t}\NormalTok{ token\_start}\OperatorTok{,}\NormalTok{ token\_end}\OperatorTok{;}
    \DataTypeTok{int64\_t}\NormalTok{ file\_start}\OperatorTok{,}\NormalTok{ file\_end}\OperatorTok{;}
    \DataTypeTok{size\_t}\NormalTok{ address}\OperatorTok{;}       \CommentTok{// byte offset in .offsets file (optional)}
    \BuiltInTok{std::}\NormalTok{string text}\OperatorTok{;}     \CommentTok{// populated lazily or by caller}
\OperatorTok{\};}
\end{Highlighting}
\end{Shaded}

\textbf{Important details:} - \texttt{append()} will: - chunk long
sentences into overlapping spans if configured to do so, - write
chunk(s) into \texttt{sentences.txt} and update an \texttt{OffsetEntry}
for each chunk, - add chunk embedding into the HNSW graph with the
returned label, - increment \texttt{dirty\_count} and flush HNSW when
\texttt{dirty\_count\ \textgreater{}=\ cfg.flush\_every}. -
\texttt{remove()} should use HNSW's delete/markDeleted semantics;
offsets keep an entry with \texttt{file\_start==file\_end==0} to
indicate deleted records. - \texttt{flush()} should msync only changed
portions of the offsets mmap and optionally call
\texttt{hnsw\_index-\textgreater{}saveIndex()} in batches to avoid
constant re-saving after every append.

\begin{center}\rule{0.5\linewidth}{0.5pt}\end{center}

\subsection{Chunking Strategy}\label{chunking-strategy}

The main chunking strategies used in the field are: - Size-based
chunking: A simple method of splitting a document into chunks of a fixed
number of words or characters. - Paragraph-based chunking: Splitting a
document into chunks based on its paragraphs. This is useful for highly
structured documents. - Semantic chunking: A more advanced method that
uses the meaning of the text to decide where to split chunks, aiming to
keep related ideas together. - Sliding window chunking: A technique that
creates overlapping chunks to ensure that context is not lost at the
boundaries between chunks.

We use a synergy of these methods. For the semantic side we view the
structural nature of a document (both explicit and implicit) as designed
by the author to communicate meaning and as such as a good indication of
semantic context. Paragraph chunking is a specific casebut we consider
any fields/paths (explicit and implicit) designated for dense indexing.
These ``fields'' are then fed into the system and when above a certain
length are exposed to a sliding window chunking whose overlap can be
pre-configured.

\begin{center}\rule{0.5\linewidth}{0.5pt}\end{center}

\subsubsection{\texorpdfstring{\texttt{ShardedIndex}}{ShardedIndex}}\label{shardedindex}

\textbf{Purpose:} Manages a collection of \texttt{BertIndex} shards for
scaling past a single HNSW capacity limit. Supports adding shards,
choosing a shard for new appends, merging shards, parallel searches and
shard-level operations.

\textbf{Key methods (example):}

\begin{Shaded}
\begin{Highlighting}[]
\KeywordTok{class}\NormalTok{ ShardedIndex }\OperatorTok{\{}
\KeywordTok{public}\OperatorTok{:}
\NormalTok{    ShardedIndex}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{base\_name}\OperatorTok{,} \AttributeTok{const}\NormalTok{ HnswConfig }\OperatorTok{\&}\NormalTok{cfg}\OperatorTok{);}

    \DataTypeTok{void}\NormalTok{ add\_shard}\OperatorTok{();}
    \DataTypeTok{size\_t}\NormalTok{ shard\_count}\OperatorTok{()} \AttributeTok{const}\OperatorTok{;}
    \DataTypeTok{void}\NormalTok{ append}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{sentence}\OperatorTok{,} \DataTypeTok{int64\_t}\NormalTok{ sentence\_id}\OperatorTok{);}
    \DataTypeTok{void}\NormalTok{ remove}\OperatorTok{(}\DataTypeTok{size\_t}\NormalTok{ label}\OperatorTok{,} \DataTypeTok{size\_t}\NormalTok{ shard }\OperatorTok{=} \DecValTok{0}\OperatorTok{);}
    \DataTypeTok{void}\NormalTok{ delete\_byAddress}\OperatorTok{(}\DataTypeTok{int64\_t}\NormalTok{ addr}\OperatorTok{,} \DataTypeTok{size\_t}\NormalTok{ shard }\OperatorTok{=} \DecValTok{0}\OperatorTok{);}
    \DataTypeTok{void}\NormalTok{ merge\_last\_two}\OperatorTok{();}        \CommentTok{// compaction: merge last two shards to reduce fragmentation}
    \DataTypeTok{void}\NormalTok{ flush}\OperatorTok{();}

    \CommentTok{// search across shards (parallel)}
    \BuiltInTok{std::}\NormalTok{vector}\OperatorTok{\textless{}}\NormalTok{SearchResult}\OperatorTok{\textgreater{}}\NormalTok{ knn}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{q}\OperatorTok{,} \DataTypeTok{size\_t}\NormalTok{ k}\OperatorTok{);}
    \BuiltInTok{std::}\NormalTok{vector}\OperatorTok{\textless{}}\NormalTok{SearchResult}\OperatorTok{\textgreater{}}\NormalTok{ radius}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{q}\OperatorTok{,} \DataTypeTok{float}\NormalTok{ radius}\OperatorTok{);}
    \BuiltInTok{std::}\NormalTok{vector}\OperatorTok{\textless{}}\NormalTok{SearchResult}\OperatorTok{\textgreater{}}\NormalTok{ adaptive}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{q}\OperatorTok{,} \DataTypeTok{float}\NormalTok{ alpha}\OperatorTok{,} \DataTypeTok{size\_t}\NormalTok{ minN}\OperatorTok{,} \DataTypeTok{size\_t}\NormalTok{ lookahead}\OperatorTok{,} \DataTypeTok{float}\NormalTok{ gapDelta}\OperatorTok{);}
\OperatorTok{\};}
\end{Highlighting}
\end{Shaded}

\textbf{Notes:} - On initialization, \texttt{ShardedIndex} discovers
shard files by scanning for
\texttt{\textless{}base\textgreater{}\_shard\textless{}i\textgreater{}.*}
starting at 0 until a missing index is found. It loads all shards into
memory (can be parallelized). - \texttt{append()} selects the last shard
unless it is full, in which case \texttt{add\_shard()} is called. -
\texttt{merge\_last\_two()} (optionally parallel) creates a merged
shard, then atomically replaces the two old files and updates the shard
table.

\begin{center}\rule{0.5\linewidth}{0.5pt}\end{center}

\subsubsection{\texorpdfstring{\texttt{BertIndexManager}}{BertIndexManager}}\label{bertindexmanager}

\textbf{Purpose:} A simple namespace manager mapping names to
\texttt{ShardedIndex} instances. Provides REPL handling helpers and
convenience operations for multiple named datasets.

\textbf{Selected API:}

\begin{Shaded}
\begin{Highlighting}[]
\KeywordTok{class}\NormalTok{ BertIndexManager }\OperatorTok{\{}
\KeywordTok{public}\OperatorTok{:}
\NormalTok{    BertIndexManager}\OperatorTok{(}\AttributeTok{const}\NormalTok{ HnswConfig }\OperatorTok{\&}\NormalTok{cfg}\OperatorTok{);}

\NormalTok{    ShardedIndex }\OperatorTok{\&}\NormalTok{getOrCreate}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{name}\OperatorTok{);}
    \DataTypeTok{void}\NormalTok{ load\_or\_create}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{name}\OperatorTok{);}
    \DataTypeTok{void}\NormalTok{ use}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{name}\OperatorTok{);}

    \BuiltInTok{std::}\NormalTok{vector}\OperatorTok{\textless{}}\NormalTok{SearchResult}\OperatorTok{\textgreater{}}\NormalTok{ knn}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{name}\OperatorTok{,} \AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{q}\OperatorTok{,} \DataTypeTok{size\_t}\NormalTok{ k}\OperatorTok{);}
    \DataTypeTok{void}\NormalTok{ append}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{name}\OperatorTok{,} \AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{sentence}\OperatorTok{);}
    \DataTypeTok{void}\NormalTok{ appendid}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{name}\OperatorTok{,} \DataTypeTok{int64\_t}\NormalTok{ sid}\OperatorTok{,} \AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{sentence}\OperatorTok{);}
    \DataTypeTok{void}\NormalTok{ flush}\OperatorTok{(}\AttributeTok{const} \BuiltInTok{std::}\NormalTok{string }\OperatorTok{\&}\NormalTok{name}\OperatorTok{);}
\OperatorTok{\};}
\end{Highlighting}
\end{Shaded}

