\subsection{Quick Start Examples}\label{quick-start-examples}

\textbf{Create index and append:}

\begin{Shaded}
\begin{Highlighting}[]
\NormalTok{HnswConfig cfg}\OperatorTok{;}
\NormalTok{cfg}\OperatorTok{.}\NormalTok{metric }\OperatorTok{=} \StringTok{"cosine"}\OperatorTok{;}
\NormalTok{cfg}\OperatorTok{.}\NormalTok{max\_elements }\OperatorTok{=} \DecValTok{100000}\OperatorTok{;}
\NormalTok{BertIndexManager manager}\OperatorTok{(}\NormalTok{cfg}\OperatorTok{);}
\NormalTok{manager}\OperatorTok{.}\NormalTok{load\_or\_create}\OperatorTok{(}\StringTok{"default"}\OperatorTok{);}
\NormalTok{manager}\OperatorTok{.}\NormalTok{append}\OperatorTok{(}\StringTok{"He develops in C++"}\OperatorTok{);}
\NormalTok{manager}\OperatorTok{.}\NormalTok{appendid}\OperatorTok{(}\DecValTok{1001}\OperatorTok{,} \StringTok{"She likes Prolog"}\OperatorTok{);}
\NormalTok{manager}\OperatorTok{.}\NormalTok{flush}\OperatorTok{(}\StringTok{"default"}\OperatorTok{);}
\end{Highlighting}
\end{Shaded}

\textbf{Search (kNN):}

\begin{Shaded}
\begin{Highlighting}[]
\KeywordTok{auto}\NormalTok{ res }\OperatorTok{=}\NormalTok{ manager}\OperatorTok{.}\NormalTok{knn}\OperatorTok{(}\StringTok{"default"}\OperatorTok{,} \StringTok{"what language does he use?"}\OperatorTok{,} \DecValTok{5}\OperatorTok{);}
\ControlFlowTok{for} \OperatorTok{(}\KeywordTok{auto} \OperatorTok{\&}\NormalTok{r }\OperatorTok{:}\NormalTok{ res}\OperatorTok{)} \OperatorTok{\{}
    \BuiltInTok{std::}\NormalTok{cout }\OperatorTok{\textless{}\textless{}}\NormalTok{ r}\OperatorTok{.}\NormalTok{score }\OperatorTok{\textless{}\textless{}} \StringTok{" "} \OperatorTok{\textless{}\textless{}}\NormalTok{ r}\OperatorTok{.}\NormalTok{text }\OperatorTok{\textless{}\textless{}} \BuiltInTok{std::}\NormalTok{endl}\OperatorTok{;}
\OperatorTok{\}}
\end{Highlighting}
\end{Shaded}

\textbf{Merge last two shards:}

\begin{Shaded}
\begin{Highlighting}[]
\KeywordTok{auto} \OperatorTok{\&}\NormalTok{sh }\OperatorTok{=}\NormalTok{ manager}\OperatorTok{.}\NormalTok{getOrCreate}\OperatorTok{(}\StringTok{"default"}\OperatorTok{);}
\NormalTok{sh}\OperatorTok{.}\NormalTok{merge\_last\_two}\OperatorTok{();}
\NormalTok{sh}\OperatorTok{.}\NormalTok{flush}\OperatorTok{();}
\end{Highlighting}
\end{Shaded}

\begin{center}\rule{0.5\linewidth}{0.5pt}\end{center}

\subsection{Developer Checklist \&
Tests}\label{developer-checklist-tests}

\textbf{Startup checks:} - {[} {]} \texttt{offsets.bin} header matches
expected format. - {[} {]} highest SID is computed and
\texttt{auto\_sentence\_id} resumed. - {[} {]} HNSW metric/dim
validation against metadata.

\textbf{Integration tests:} - Small test corpus (4-8 sentences) and
expected ranking results for several queries. - Test append+restart:
append, exit, restart, append more; ensure SID incrementing persists and
no collisions. - Test delete+undelete and reclaim label space. - Test
merge\_last\_two preserves SIDs and deletes old files safely.

\begin{center}\rule{0.5\linewidth}{0.5pt}\end{center}

