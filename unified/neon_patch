// ============================================================================
// NEON-optimized normalization functions
// ============================================================================

#ifdef __ARM_NEON

inline void normalize_vector_neon(float* data, size_t dim) {
    float32x4_t sum_vec = vdupq_n_f32(0.0f);
    
    size_t i = 0;
    // Compute squared sum
    for (; i + 4 <= dim; i += 4) {
        float32x4_t v = vld1q_f32(data + i);
        sum_vec = vmlaq_f32(sum_vec, v, v);
    }
    
    float32x2_t sum_2 = vadd_f32(vget_low_f32(sum_vec), vget_high_f32(sum_vec));
    float sum = vget_lane_f32(vpadd_f32(sum_2, sum_2), 0);
    
    for (; i < dim; i++) {
        sum += data[i] * data[i];
    }
    
    // Compute norm
    float norm = std::sqrt(sum + 1e-30f);
    float32x4_t norm_vec = vdupq_n_f32(1.0f / norm);
    
    // Normalize
    i = 0;
    for (; i + 4 <= dim; i += 4) {
        float32x4_t v = vld1q_f32(data + i);
        v = vmulq_f32(v, norm_vec);
        vst1q_f32(data + i, v);
    }
    
    float norm_scalar = 1.0f / norm;
    for (; i < dim; i++) {
        data[i] *= norm_scalar;
    }
}

#endif // __ARM_NEON

