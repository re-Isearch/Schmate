#ifdef INCLUDE_TEST

#include <iostream>
#include <chrono>
#include <random>

void test_neon_performance() {
    const size_t dim = 768;
    const size_t num_tests = 100000;
    
    std::vector<float> v1(dim);
    std::vector<float> v2(dim);
    
    std::random_device rd;
    std::mt19937 gen(rd());
    std::normal_distribution<float> dist(0.0f, 1.0f);
    
    for (auto& x : v1) x = dist(gen);
    for (auto& x : v2) x = dist(gen);
    
    // Test L2 distance
    auto start = std::chrono::high_resolution_clock::now();
    float result = 0.0f;
    for (size_t i = 0; i < num_tests; i++) {
#ifdef __ARM_NEON
        result += hnswlib::L2SqrNEON(v1.data(), v2.data(), &dim);
#else
        result += hnswlib::L2Sqr(v1.data(), v2.data(), &dim);
#endif
    }
    auto end = std::chrono::high_resolution_clock::now();
    
    auto duration = std::chrono::duration_cast<std::chrono::nanoseconds>(end - start).count();
    
    std::cout << "L2 Distance:\n";
    std::cout << "  Total time: " << (duration / 1e6) << " ms\n";
    std::cout << "  Per distance: " << (duration / num_tests) << " ns\n";
    std::cout << "  Result (to prevent optimization): " << result << "\n";
}

#endif // INCLUDE_TEST
