// ============================================================================
// Modified L2Space class with NEON support
// ============================================================================

class L2Space : public SpaceInterface<float> {
    DISTFUNC<float> fstdistfunc_;
    size_t data_size_;
    size_t dim_;

public:
    L2Space(size_t dim) {
        // Select the appropriate distance function based on available SIMD
#if defined(USE_AVX512)
        fstdistfunc_ = L2SqrSIMD16ExtAVX512;
#elif defined(USE_AVX)
        fstdistfunc_ = L2SqrSIMD16Ext;
#elif defined(__ARM_NEON)
        fstdistfunc_ = L2SqrNEON16Ext;
#else
        fstdistfunc_ = L2Sqr;
#endif
        dim_ = dim;
        data_size_ = dim * sizeof(float);
    }

    size_t get_data_size() {
        return data_size_;
    }

    DISTFUNC<float> get_dist_func() {
        return fstdistfunc_;
    }

    void *get_dist_func_param() {
        return &dim_;
    }

    ~L2Space() {}
};

// ============================================================================
// Modified InnerProductSpace class with NEON support
