    // Set enable_rescoring_ = false in metadata
}

// Advanced: Manual compaction control
class UnifiedIndexAdvanced : public UnifiedIndex {
private:
    size_t saves_since_compact_ = 0;
    
public:
    void saveIndex(const std::string& path) override {
        saves_since_compact_++;
        
        // Option 1: Compact every N saves (e.g., every 10 saves)
        bool should_compact = (saves_since_compact_ >= 10);
        
        // Option 2: Compact based on delta count
        auto stats = vector_storage_.get_stats();
        should_compact = should_compact || (stats.delta_files >= 20);
        
        if (should_compact) {
            // Full save with compaction
            UnifiedIndex::saveIndex(path);
            saves_since_compact_ = 0;
        } else {
            // Quick save - just flush current delta, don't compact
            vector_storage_.flush_delta();
            
            // Save HNSW structure
            std::ofstream ofs(path, std::ios::binary);
            meta_.save(ofs);
            
            // Write consolidated vectors
            vector_storage_.save_vectors_to_stream(ofs);
            
            if (float_index_) {
                float_index_->saveIndex(ofs);
            } else if (quant_index_) {
                quant_index_->saveIndex(ofs);
            }
            ofs.close();
        }
    }
};

// Configuration options:
struct VectorStorageConfig {
    VectorStorageMode mode = VectorStorageMode::MEMORY_MAPPED;
    size_t flush_threshold = 10000;  // Flush delta every N additions
    size_t compact_threshold = 20;   // Compact when delta count reaches N
    bool auto_compact_on_save = true;
};
