#include "HFModelMapper.hpp"
#include <cstring>

HFModelMapper::HFModelMapper() : count(0) {
    for (auto& m : mappings) {
        m.active = false;
    }
}

bool HFModelMapper::set(const std::string& key, const std::string& repo, const std::string& filename) {
    if (key.empty() || key.size() >= ModelPathStore::KEY_SIZE ||
        repo.size() >= MAX_REPO_SIZE || filename.size() >= MAX_FILENAME_SIZE) {
        return false;
    }
    
    // Check if key exists
    for (auto& m : mappings) {
        if (m.active && std::strcmp(m.key, key.c_str()) == 0) {
            std::strncpy(m.repo, repo.c_str(), MAX_REPO_SIZE - 1);
            m.repo[MAX_REPO_SIZE - 1] = '\0';
            std::strncpy(m.filename, filename.c_str(), MAX_FILENAME_SIZE - 1);
            m.filename[MAX_FILENAME_SIZE - 1] = '\0';
            return true;
        }
    }
    
    // Add new mapping
    if (count >= ModelPathStore::MAX_ENTRIES) {
        return false;
    }
    
    for (auto& m : mappings) {
        if (!m.active) {
            std::strncpy(m.key, key.c_str(), ModelPathStore::KEY_SIZE - 1);
            m.key[ModelPathStore::KEY_SIZE - 1] = '\0';
            std::strncpy(m.repo, repo.c_str(), MAX_REPO_SIZE - 1);
            m.repo[MAX_REPO_SIZE - 1] = '\0';
            std::strncpy(m.filename, filename.c_str(), MAX_FILENAME_SIZE - 1);
            m.filename[MAX_FILENAME_SIZE - 1] = '\0';
            m.active = true;
            count++;
            return true;
        }
    }
    
    return false;
}

std::optional<std::string> HFModelMapper::getRepo(const std::string& key) const {
    for (const auto& m : mappings) {
        if (m.active && std::strcmp(m.key, key.c_str()) == 0) {
            return std::string(m.repo);
        }
    }
    return std::nullopt;
}

std::optional<std::string> HFModelMapper::getFilename(const std::string& key) const {
    for (const auto& m : mappings) {
        if (m.active && std::strcmp(m.key, key.c_str()) == 0) {
            return std::string(m.filename);
        }
    }
    return std::nullopt;
}

std::optional<std::string> HFModelMapper::getFullPath(const std::string& key) const {
    for (const auto& m : mappings) {
        if (m.active && std::strcmp(m.key, key.c_str()) == 0) {
            return std::string(m.repo) + "/" + std::string(m.filename);
        }
    }
    return std::nullopt;
}

std::optional<std::string> HFModelMapper::getDownloadURL(const std::string& key) const {
    for (const auto& m : mappings) {
        if (m.active && std::strcmp(m.key, key.c_str()) == 0) {
            return "https://huggingface.co/" + std::string(m.repo) + 
                   "/resolve/main/" + std::string(m.filename);
        }
    }
    return std::nullopt;
}

bool HFModelMapper::remove(const std::string& key) {
    for (auto& m : mappings) {
        if (m.active && std::strcmp(m.key, key.c_str()) == 0) {
            m.active = false;
            count--;
            return true;
        }
    }
    return false;
}

void HFModelMapper::clear() {
    for (auto& m : mappings) {
        m.active = false;
    }
    count = 0;
}

bool HFModelMapper::save(const std::string& filename) const {
    std::ofstream file(filename, std::ios::binary);
    if (!file) return false;
    
    file.write(reinterpret_cast<const char*>(&count), sizeof(count));
    file.write(reinterpret_cast<const char*>(mappings.data()), 
               sizeof(HFMapping) * ModelPathStore::MAX_ENTRIES);
    
    return file.good();
}

bool HFModelMapper::load(const std::string& filename) {
    std::ifstream file(filename, std::ios::binary);
    if (!file) return false;
    
    file.read(reinterpret_cast<char*>(&count), sizeof(count));
    file.read(reinterpret_cast<char*>(mappings.data()), 
              sizeof(HFMapping) * ModelPathStore::MAX_ENTRIES);
    
    return file.good();
}

bool HFModelMapper::exportToText(const std::string& filename) const {
    std::ofstream file(filename);
    if (!file) return false;
    
    for (const auto& m : mappings) {
        if (m.active) {
            file << m.key << "=" << m.repo << "|" << m.filename << "\n";
        }
    }
    
    return file.good();
}

bool HFModelMapper::importFromText(const std::string& filename) {
    std::ifstream file(filename);
    if (!file) return false;
    
    clear();
    std::string line;
    while (std::getline(file, line)) {
        if (line.empty() || line[0] == '#') continue;
        
        size_t eqPos = line.find('=');
        if (eqPos == std::string::npos) continue;
        
        std::string key = line.substr(0, eqPos);
        std::string rest = line.substr(eqPos + 1);
        
        size_t pipePos = rest.find('|');
        if (pipePos == std::string::npos) continue;
        
        std::string repo = rest.substr(0, pipePos);
        std::string filename = rest.substr(pipePos + 1);
        
        // Trim whitespace
        key.erase(0, key.find_first_not_of(" \t"));
        key.erase(key.find_last_not_of(" \t") + 1);
        repo.erase(0, repo.find_first_not_of(" \t"));
        repo.erase(repo.find_last_not_of(" \t") + 1);
        filename.erase(0, filename.find_first_not_of(" \t"));
        filename.erase(filename.find_last_not_of(" \t") + 1);
        
        if (!set(key, repo, filename)) {
            return false;
        }
    }
    
    return true;
}
